select acct_no, (to_date('31-dec-1899','DD-MON-YYYY'))+tran_date "TxnDate", jrnl_no, to_date('31-dec-1899''DD-MON-YYYY')+post_date "PostDate", post_time, tran_type,decode(tran_type,1,'Financial','Non Financial')"Txntype", baseconv.convdata(var_area, 17, 4) "Tran Code", baseconv.convdata(var_area, 33, 8,3) "Amt", baseconv.convdata(var_area, 41, 8,3) "Balance", rec_no, BASECONV.CONVDATA(VAR_AREA, 29,4) "chq-no", BASECONV.CONVDATA(VAR_AREA, 25,8,3) "holdval", baseconv.convdata(var_area, 9, 8) "Maker_branch", substr(var_area, 24, 1) as "FROM/TO", substr(var_area, 10,50) as "ACCOUNT NO" from inct where inst_no = '003' and acct_no = '000000&a' order by rec_no desc;